<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ticket Management · WeWannaParty Admin</title>
  <meta name="theme-color" content="#B00000" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --primary: #B00000;
      --bg: #0A0A0A;
      --card: #111111;
      --text: #FFFFFF;
      --text-secondary: #A0A0A0;
      --text-muted: #6B6B6B;
      --border: #222222;
      --success: #10B981;
      --warning: #F59E0B;
      --danger: #EF4444;
      --radius: 12px;
    }
    body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg); color: var(--text); }
    h1, h2, h3, h4 { font-family: 'Syne', sans-serif; }
    a { color: inherit; text-decoration: none; }
    .nav {
      background: rgba(0,0,0,0.9);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-brand { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 16px; background: linear-gradient(135deg, var(--primary), #FF3333); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .nav-links { display: flex; align-items: center; gap: 20px; list-style: none; }
    .nav-links a { font-size: 13px; font-weight: 500; color: var(--text-secondary); padding: 6px 12px; border-radius: 6px; }
    .nav-links a:hover, .nav-links a.active { color: var(--text); background: rgba(255,255,255,0.04); }
    .nav-links a.active { color: var(--primary-light); }
    .container { max-width: 1200px; margin: 0 auto; padding: 32px 20px; }
    .page-title { font-size: 22px; font-weight: 800; margin-bottom: 4px; }
    .page-subtitle { color: var(--text-muted); font-size: 14px; margin-bottom: 24px; }

    .search-bar {
      display: flex;
      gap: 12px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }
    .search-bar input {
      flex: 1;
      min-width: 200px;
      padding: 12px 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      outline: none;
    }
    .search-bar input:focus { border-color: var(--primary); }
    .search-bar input::placeholder { color: var(--text-muted); }
    .search-bar button {
      padding: 12px 24px;
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
    }
    .search-bar button:hover { background: #8B0000; }

    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { text-align: left; padding: 12px 14px; color: var(--text-muted); font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid var(--border); white-space: nowrap; }
    td { padding: 14px; border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: middle; }
    tr:hover td { background: rgba(255,255,255,0.02); }

    .badge {
      display: inline-flex; padding: 3px 10px; border-radius: 100px; font-size: 11px; font-weight: 600;
    }
    .badge-unused { background: rgba(16,185,129,0.1); color: var(--success); border: 1px solid rgba(16,185,129,0.2); }
    .badge-used { background: rgba(245,158,11,0.1); color: var(--warning); border: 1px solid rgba(245,158,11,0.2); }
    .badge-cancelled { background: rgba(239,68,68,0.1); color: var(--danger); border: 1px solid rgba(239,68,68,0.2); }

    .btn-sm {
      padding: 5px 12px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      font-family: 'Inter', sans-serif;
    }
    .btn-outline-sm { background: transparent; border: 1px solid var(--border); color: var(--text-secondary); }
    .btn-outline-sm:hover { border-color: var(--text-muted); color: var(--text); }
    .btn-cancel { background: rgba(239,68,68,0.1); color: var(--danger); border: 1px solid rgba(239,68,68,0.2); }
    .btn-cancel:hover { background: rgba(239,68,68,0.2); }
    .btn-reissue { background: rgba(59,130,246,0.1); color: #3B82F6; border: 1px solid rgba(59,130,246,0.2); }
    .btn-reissue:hover { background: rgba(59,130,246,0.2); }

    .actions { display: flex; gap: 4px; flex-wrap: wrap; }
    .empty { text-align: center; padding: 48px; color: var(--text-muted); font-size: 14px; }
    .spinner-sm { display:inline-block; width:14px; height:14px; border:2px solid rgba(255,255,255,0.3); border-top-color:#fff; border-radius:50%; animation:spin 0.6s linear infinite; vertical-align:middle; }
    @keyframes spin { to { transform:rotate(360deg); } }
    .btn-sm:disabled { opacity:0.5; cursor:not-allowed; }

    .toast {
      position: fixed; bottom: 24px; right: 24px;
      padding: 14px 20px; border-radius: 10px; font-size: 13px; z-index: 300;
      display: none; animation: slideUp 0.3s ease;
    }
    .toast-success { background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3); color: var(--success); display: block; }
    .toast-error { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: var(--danger); display: block; }
    @keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    @media (max-width: 768px) {
      table { font-size: 12px; }
      th, td { padding: 8px 6px; }
      .container { padding: 20px 14px; }
    }
  </style>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <div class="nav-brand">WeWannaParty Admin</div>
      <ul class="nav-links">
        <li><a href="/admin/dashboard">Dashboard</a></li>
        <li><a href="/admin/payments">Payments</a></li>
        <li><a href="/admin/tickets" class="active">Tickets</a></li>
        <li><a href="/admin/scanner">Scanner</a></li>
        <li><a href="/admin/logout">Logout</a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <h1 class="page-title">Ticket Management</h1>
    <p class="page-subtitle">Search, cancel, reissue, and manage tickets</p>

    <form class="search-bar" method="GET" action="/admin/tickets">
      <input type="text" name="search" placeholder="Search by Ticket #, Booking #, Customer, Phone, or QR..." value="<%= search %>" />
      <button type="submit">Search</button>
      <% if (search) { %><a href="/admin/tickets" style="display:inline-flex;align-items:center;padding:12px 16px;color:var(--text-muted);font-size:13px;">Clear</a><% } %>
    </form>

    <div class="table-wrap">
      <% if (tickets.length === 0) { %>
        <div class="empty"><%= search ? 'No tickets match your search.' : 'No tickets issued yet.' %></div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Ticket #</th>
            <th>Booking #</th>
            <th>Event</th>
            <th>Type</th>
            <th>Holder</th>
            <th>Phone</th>
            <th>Status</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% tickets.forEach(t => { %>
          <tr>
            <td style="font-family:monospace;font-size:11px;"><%= t.ticket_number %></td>
            <td style="font-family:monospace;font-size:11px;"><%= t.booking_number %></td>
            <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= t.event_name %></td>
            <td><%= t.ticket_type %></td>
            <td><%= t.holder_name || t.b_customer || '—' %></td>
            <td><%= t.phone || '—' %></td>
            <td><span class="badge badge-<%= t.status %>"><%= t.status.charAt(0).toUpperCase() + t.status.slice(1) %></span></td>
            <td style="white-space:nowrap;font-size:12px;"><%= t.created_at %></td>
            <td>
              <div class="actions">
                <% if (t.status === 'unused') { %>
                  <button class="btn-sm btn-cancel" onclick="cancelTicket(<%= t.id %>, this)">Cancel</button>
                <% } %>
                <% if (t.status === 'cancelled' || t.status === 'used') { %>
                  <button class="btn-sm btn-reissue" onclick="reissueTicket(<%= t.id %>, this)">Reissue</button>
                <% } %>
                <% if (t.status === 'unused') { %>
                  <button class="btn-sm btn-outline-sm" onclick="showQR(<%= t.id %>, this)">Show QR</button>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    function showToast(msg, type) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = 'toast toast-' + type;
      setTimeout(() => t.className = 'toast', 4000);
    }

    async function cancelTicket(id, el) {
      if (!confirm('Cancel this ticket? It will no longer be valid for entry.')) return;
      const btn = el || event.target;
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-sm"></span>';
      try {
        const res = await fetch('/admin/api/ticket/' + id + '/cancel', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await res.json();
        if (data.success) { showToast('Ticket cancelled.', 'success'); setTimeout(() => location.reload(), 1000); }
        else { showToast(data.message, 'error'); btn.disabled=false; btn.textContent='Cancel'; }
      } catch (e) { showToast('Error.', 'error'); btn.disabled=false; btn.textContent='Cancel'; }
    }

    async function reissueTicket(id, el) {
      if (!confirm('Reissue this ticket? A new ticket number and QR code will be generated.')) return;
      const btn = el || event.target;
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-sm"></span>';
      try {
        const res = await fetch('/admin/api/ticket/' + id + '/reissue', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await res.json();
        if (data.success) { showToast('Ticket reissued.', 'success'); setTimeout(() => location.reload(), 1000); }
        else { showToast(data.message, 'error'); btn.disabled=false; btn.textContent='Reissue'; }
      } catch (e) { showToast('Error.', 'error'); btn.disabled=false; btn.textContent='Reissue'; }
    }

    async function showQR(id, el) {
      const btn = el || event.target;
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-sm"></span>';
      try {
        const res = await fetch('/api/ticket/' + id + '/qr');
        const data = await res.json();
        if (data.success) {
          const win = window.open('', '_blank');
          win.document.write(`
            <html><head><title>Ticket QR Code</title>
            <style>
              body { display:flex;align-items:center;justify-content:center;min-height:100vh;background:#0A0A0A;flex-direction:column;font-family:sans-serif; }
              img { max-width:300px;border-radius:12px; }
              p { color:#888;margin-top:12px;font-size:13px; }
            </style></head>
            <body>
              <img src="${data.qrImage}" alt="QR Code" />
              <p>Ticket: ${data.ticketNumber}</p>
              <p style="font-size:11px;color:#555;">Scan this QR at the venue for entry</p>
            </body></html>
          `);
        } else { showToast('Error loading QR.', 'error'); btn.disabled=false; btn.textContent='Show QR'; }
      } catch (e) { showToast('Error.', 'error'); btn.disabled=false; btn.textContent='Show QR'; }
    }
  </script>
</body>
</html>
